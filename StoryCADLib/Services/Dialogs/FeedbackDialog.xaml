<Page
    x:Class="StoryCADLib.Services.Dialogs.FeedbackDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid MinWidth="520">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MaxWidth="160" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="120" />
            <RowDefinition Height="*" MinHeight="120" />
        </Grid.RowDefinitions>

        <!-- Warning to users to only submit meaningful feedback -->
        <InfoBar Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                 Severity="Informational" HorizontalAlignment="Stretch"
                 Title="Detailed feedback is addressed quicker"
                 IsOpen="True" IsClosable="False" Margin="10,0,10,10" />

        <TextBox Grid.Row="1" Grid.Column="1" Header="Issue Title"
                 Margin="10,0,0,0"
                 Text="{x:Bind FeedbackVM.Title, Mode=TwoWay}"
                 AutomationProperties.AutomationId="IssueTitleTextBox" />

        <ComboBox Grid.Row="1" Grid.Column="0" Header="Type"
                  SelectedIndex="{x:Bind FeedbackVM.FeedbackType, Mode=TwoWay}"
                  HorizontalAlignment="Stretch" SelectionChanged="ChangeUIText"
                  AutomationProperties.AutomationId="FeedbackTypeCombo">
            <ComboBoxItem Content="Bug Report" />
            <ComboBoxItem Content="Feature Request" />
        </ComboBox>

        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="10,2,10,2">
            <TextBlock Text="{x:Bind FeedbackVM.TitleError, Mode=OneWay}"
                       Foreground="Red"
                       Visibility="{x:Bind FeedbackVM.TitleErrorVisibility, Mode=OneWay}" />
            <TextBlock Text="{x:Bind FeedbackVM.BodyError, Mode=OneWay}"
                       Foreground="Red"
                       Visibility="{x:Bind FeedbackVM.BodyErrorVisibility, Mode=OneWay}" />
        </StackPanel>

        <!-- Header is bound (toggles "Issue"/"Feature Description" with the Type combo) rather than
             literal, but a bound Header still reaches the framework name at runtime like a literal
             one, so no explicit Name is added here. -->
        <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Stretch"
                 Header="{x:Bind FeedbackVM.DescriptionTitle, Mode=TwoWay}"
                 Text="{x:Bind FeedbackVM.Body, Mode=TwoWay}" TextWrapping="Wrap"
                 AcceptsReturn="True"
                 PlaceholderText="{x:Bind FeedbackVM.DescriptionPlaceholderText, Mode=TwoWay}"
                 AutomationProperties.AutomationId="FeedbackBodyTextBox" />

        <TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Stretch"
                 Header="{x:Bind FeedbackVM.ExtraStepsTitle, Mode=TwoWay}" MinHeight="50"
                 Text="{x:Bind FeedbackVM.ExtraStepsText, Mode=TwoWay}" TextWrapping="Wrap"
                 AcceptsReturn="True"
                 PlaceholderText="{x:Bind FeedbackVM.ExtraStepsPlaceholderText, Mode=TwoWay}"
                 AutomationProperties.AutomationId="FeedbackExtraStepsTextBox" />
    </Grid>
</Page>
