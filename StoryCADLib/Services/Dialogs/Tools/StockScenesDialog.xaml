<Page
    x:Class="StoryCADLib.Services.Dialogs.Tools.StockScenesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Margin="10,0">
        <ComboBox Header="Scene Categories" Margin="0,0,0,10" Width="400" HorizontalAlignment="Center"
                  ItemsSource="{x:Bind StockScenesVm.StockSceneCategories, Mode=TwoWay}"
                  SelectedItem="{x:Bind StockScenesVm.CategoryName, Mode=TwoWay}"
                  AutomationProperties.AutomationId="StockScenesCategoryCombo" />
        <!-- ListView.Header's UIA Name derivation is unverified (the Unit 1 live probe covered
             TextBox-family Headers only), so the Name is pinned explicitly (PR #1457 ruling). -->
        <ListView VerticalAlignment="Stretch" Header="Scenes" Width="400" Height="420" SelectedIndex="1"
                  ItemsSource="{x:Bind StockScenesVm.StockSceneList, Mode=TwoWay}"
                  SelectedItem="{x:Bind StockScenesVm.SceneName, Mode=TwoWay}"
                  AutomationProperties.AutomationId="StockScenesSceneList"
                  AutomationProperties.Name="Scenes" />
    </StackPanel>
</Page>
