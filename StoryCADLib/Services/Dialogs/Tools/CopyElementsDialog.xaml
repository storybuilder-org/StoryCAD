<Page
    x:Class="StoryCADLib.Services.Dialogs.Tools.CopyElementsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="10" Width="700">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Target File Picker -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Target:" VerticalAlignment="Center" Margin="0,0,10,0" />
            <!-- Prefixed CopyElements...: plain Button, not a controls:BrowseTextBox instance
                 (that control's internal Browse button carries the literal id "BrowseButton"). -->
            <Button Grid.Column="1" Content="Browse..." Margin="0,0,10,0"
                    Command="{x:Bind VM.BrowseTargetCommand}"
                    AutomationProperties.AutomationId="CopyElementsBrowseButton" />
            <!-- No Header, PlaceholderText only; visible label is the sibling "Target:" TextBlock.
                 Founder ruling on PR #1457: a sibling-TextBlock label is mirrored as a literal Name;
                 LabeledBy is not used in this codebase. -->
            <TextBox Grid.Column="2" IsReadOnly="True"
                     Text="{x:Bind VM.TargetFilePath, Mode=OneWay}"
                     PlaceholderText="Select a target outline file..."
                     AutomationProperties.AutomationId="CopyElementsTargetTextBox"
                     AutomationProperties.Name="Target" />
        </Grid>

        <!-- Row 1: Filter ComboBox -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Filter:" VerticalAlignment="Center" Margin="0,0,10,0" />
            <!-- No Header, PlaceholderText only; visible label is the sibling "Filter:" TextBlock.
                 Mirrored as a literal Name per the same PR #1457 ruling as the Target TextBox above. -->
            <ComboBox Grid.Column="1" Name="FilterComboBox"
                      ItemsSource="{x:Bind VM.CopyableTypes}"
                      SelectedItem="{x:Bind VM.SelectedFilterType, Mode=TwoWay}"
                      SelectionChanged="FilterComboBox_SelectionChanged"
                      PlaceholderText="Select element type..."
                      MinWidth="200"
                      AutomationProperties.AutomationId="CopyElementsFilterCombo"
                      AutomationProperties.Name="Filter" />
        </Grid>

        <!-- Row 2: Dual ListView with Button Bar -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Pane: Source (Current Outline) -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="SOURCE (Current Outline)"
                           FontWeight="SemiBold" Margin="0,0,0,5" />
                <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1">
                    <ScrollViewer Height="300">
                        <ListView Name="SourceListView"
                                  ItemsSource="{x:Bind VM.SourceElements, Mode=OneWay}"
                                  SelectedItem="{x:Bind VM.SelectedSourceElement, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  SelectionMode="Single"
                                  AutomationProperties.AutomationId="CopyElementsSourceList" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Center: Button Bar -->
            <!-- Icon-only buttons (glyph Content, no plain text): Name mirrors the ToolTip text
                 per the Shell Move-flyout precedent. Prefixed CopyElements... because MoveUpButton/
                 MoveDownButton are already taken globally by Shell.xaml's Move flyout. -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                <Button Content="&#x2192;" FontFamily="Segoe UI Symbol" Width="40" Height="40"
                        Margin="0,5" ToolTipService.ToolTip="Copy to target"
                        Command="{x:Bind VM.CopyElementCommand}"
                        AutomationProperties.AutomationId="CopyElementsCopyButton"
                        AutomationProperties.Name="Copy to target" />
                <Button Content="&#x2190;" FontFamily="Segoe UI Symbol" Width="40" Height="40"
                        Margin="0,5" ToolTipService.ToolTip="Remove from target (session only)"
                        Command="{x:Bind VM.RemoveElementCommand}"
                        AutomationProperties.AutomationId="CopyElementsRemoveButton"
                        AutomationProperties.Name="Remove from target (session only)" />
                <Button Content="&#x2191;" FontFamily="Segoe UI Symbol" Width="40" Height="40"
                        Margin="0,5" ToolTipService.ToolTip="Move up"
                        Command="{x:Bind VM.MoveUpCommand}"
                        AutomationProperties.AutomationId="CopyElementsMoveUpButton"
                        AutomationProperties.Name="Move up" />
                <Button Content="&#x2193;" FontFamily="Segoe UI Symbol" Width="40" Height="40"
                        Margin="0,5" ToolTipService.ToolTip="Move down"
                        Command="{x:Bind VM.MoveDownCommand}"
                        AutomationProperties.AutomationId="CopyElementsMoveDownButton"
                        AutomationProperties.Name="Move down" />
            </StackPanel>

            <!-- Right Pane: Target (Opened File) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="TARGET (Opened File)"
                           FontWeight="SemiBold" Margin="0,0,0,5" />
                <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1">
                    <ScrollViewer Height="300">
                        <ListView Name="TargetListView"
                                  ItemsSource="{x:Bind VM.TargetElements, Mode=OneWay}"
                                  SelectedItem="{x:Bind VM.SelectedTargetElement, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  SelectionMode="Single"
                                  AutomationProperties.AutomationId="CopyElementsTargetList" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- Row 3: Status Bar -->
        <Grid Grid.Row="3">
            <TextBlock Text="{x:Bind VM.StatusMessage, Mode=OneWay}"
                       VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Page>
