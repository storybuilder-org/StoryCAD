<Page
    x:Class="StoryCADLib.Services.Dialogs.Tools.DramaticSituationsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- No Header and no sibling label TextBlock at all; the dialog's own title is the only
         context, so Name states the function per the "no clean visible label" principle. -->
    <ComboBox Width="400" ItemsSource="{x:Bind DramaticSituationsVm.SituationsSource, Mode=TwoWay}"
              SelectedItem="{x:Bind DramaticSituationsVm.SituationName, Mode=TwoWay}"
              AutomationProperties.AutomationId="DramaticSituationCombo"
              AutomationProperties.Name="Dramatic Situation" />
</Page>
