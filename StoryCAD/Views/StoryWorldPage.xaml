<Page NavigationCacheMode="Required"
      x:Class="StoryCAD.Views.StoryWorldPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:usercontrols="using:StoryCADLib.Controls"
      mc:Ignorable="d"
      ScrollViewer.VerticalScrollBarVisibility="Disabled"
      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Name field (derived from story name, read-only) -->
        <TextBlock Text="{x:Bind StoryWorldVm.Name, Mode=OneWay}"
                   FontSize="20" FontWeight="SemiBold" Margin="12,8,12,4" />

        <!-- Tab View with 9 tabs -->
        <TabView Grid.Row="1" TabWidthMode="Equal" CanDragTabs="False" CanReorderTabs="False" IsAddTabButtonVisible="False"
                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                 HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
            <TabView.TabItems>

                <!-- Tab 1: Structure (World Type Classification) -->
                <TabViewItem Header="Structure" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ComboBox Grid.Row="0" Header="World Type" MinWidth="250" Margin="12,12,12,0"
                                  ItemsSource="{x:Bind StoryWorldVm.WorldTypeList}"
                                  SelectedItem="{x:Bind StoryWorldVm.WorldType, Mode=TwoWay}"
                                  PlaceholderText="Select the type of world..."/>

                        <!-- Advanced Options Expander -->
                        <Expander Grid.Row="1" Header="Advanced: Axis Values" HorizontalAlignment="Stretch" Margin="12,16,12,12">
                            <StackPanel Spacing="8" Padding="8">
                                <TextBlock Text="These values are derived from World Type but can be customized for Collaborator AI guidance."
                                           TextWrapping="Wrap" Foreground="Gray" FontSize="12" Margin="0,0,0,8"/>
                                <ComboBox Header="Ontology (What exists)" MinWidth="200"
                                          ItemsSource="{x:Bind StoryWorldVm.OntologyList}"
                                          SelectedItem="{x:Bind StoryWorldVm.Ontology, Mode=TwoWay}"/>
                                <ComboBox Header="World Relation (Relation to our reality)" MinWidth="200"
                                          ItemsSource="{x:Bind StoryWorldVm.WorldRelationList}"
                                          SelectedItem="{x:Bind StoryWorldVm.WorldRelation, Mode=TwoWay}"/>
                                <ComboBox Header="Rule Transparency (How rules behave)" MinWidth="200"
                                          ItemsSource="{x:Bind StoryWorldVm.RuleTransparencyList}"
                                          SelectedItem="{x:Bind StoryWorldVm.RuleTransparency, Mode=TwoWay}"/>
                                <ComboBox Header="Scale of Difference" MinWidth="200"
                                          ItemsSource="{x:Bind StoryWorldVm.ScaleOfDifferenceList}"
                                          SelectedItem="{x:Bind StoryWorldVm.ScaleOfDifference, Mode=TwoWay}"/>
                                <ComboBox Header="Agency Source (What drives change)" MinWidth="200"
                                          ItemsSource="{x:Bind StoryWorldVm.AgencySourceList}"
                                          SelectedItem="{x:Bind StoryWorldVm.AgencySource, Mode=TwoWay}"/>
                                <ComboBox Header="Tone Logic (How the world feels)" MinWidth="200"
                                          ItemsSource="{x:Bind StoryWorldVm.ToneLogicList}"
                                          SelectedItem="{x:Bind StoryWorldVm.ToneLogic, Mode=TwoWay}"/>
                            </StackPanel>
                        </Expander>
                    </Grid>
                </TabViewItem>

                <!-- Tab 2: Physical World (List - placeholder for now) -->
                <TabViewItem Header="Physical World" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid Padding="12">
                        <TextBlock Text="Physical World entries will be added here. (List tab - future implementation)"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                    </Grid>
                </TabViewItem>

                <!-- Tab 3: People/Species (List - placeholder for now) -->
                <TabViewItem Header="People/Species" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid Padding="12">
                        <TextBlock Text="People/Species entries will be added here. (List tab - future implementation)"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                    </Grid>
                </TabViewItem>

                <!-- Tab 4: Cultures (List - placeholder for now) -->
                <TabViewItem Header="Cultures" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid Padding="12">
                        <TextBlock Text="Culture entries will be added here. (List tab - future implementation)"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                    </Grid>
                </TabViewItem>

                <!-- Tab 5: Governments (List - placeholder for now) -->
                <TabViewItem Header="Governments" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid Padding="12">
                        <TextBlock Text="Government entries will be added here. (List tab - future implementation)"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                    </Grid>
                </TabViewItem>

                <!-- Tab 6: Religions (List - placeholder for now) -->
                <TabViewItem Header="Religions" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid Padding="12">
                        <TextBlock Text="Religion entries will be added here. (List tab - future implementation)"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                    </Grid>
                </TabViewItem>

                <!-- Tab 7: History (Single entry) -->
                <TabViewItem Header="History" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <usercontrols:RichEditBoxExtended Grid.Row="0" Header="Founding Events"
                                                          RtfText="{x:Bind StoryWorldVm.FoundingEvents, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          PlaceholderText="How did the current order begin?"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="1" Header="Major Conflicts"
                                                          RtfText="{x:Bind StoryWorldVm.MajorConflicts, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          PlaceholderText="What wars or struggles shaped this world?"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="2" Header="Eras"
                                                          RtfText="{x:Bind StoryWorldVm.Eras, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          PlaceholderText="What major periods or ages define this world's history?"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="3" Header="Technological Shifts"
                                                          RtfText="{x:Bind StoryWorldVm.TechnologicalShifts, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          PlaceholderText="What changes in capability occurred?"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="4" Header="Lost Knowledge"
                                                          RtfText="{x:Bind StoryWorldVm.LostKnowledge, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          PlaceholderText="What has been forgotten or destroyed?"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </TabViewItem>

                <!-- Tab 8: Economy (Single entry) -->
                <TabViewItem Header="Economy" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <usercontrols:RichEditBoxExtended Grid.Row="0" Header="Economic System"
                                                          RtfText="{x:Bind StoryWorldVm.EconomicSystem, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          PlaceholderText="How does the economy work? (capitalism, barter, etc.)"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="1" Header="Currency"
                                                          RtfText="{x:Bind StoryWorldVm.Currency, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          PlaceholderText="What is the medium of exchange?"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="2" Header="Trade Routes"
                                                          RtfText="{x:Bind StoryWorldVm.TradeRoutes, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          PlaceholderText="How do goods move around?"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="3" Header="Professions"
                                                          RtfText="{x:Bind StoryWorldVm.Professions, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          PlaceholderText="What jobs and guilds exist?"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="4" Header="Wealth Distribution"
                                                          RtfText="{x:Bind StoryWorldVm.WealthDistribution, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          PlaceholderText="Who has money? Who doesn't? Why?"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </TabViewItem>

                <!-- Tab 9: Magic/Technology (Single entry) -->
                <TabViewItem Header="Magic/Tech" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ComboBox Grid.Row="0" Header="System Type" MinWidth="200"
                                  ItemsSource="{x:Bind StoryWorldVm.SystemTypeList}"
                                  SelectedItem="{x:Bind StoryWorldVm.SystemType, Mode=TwoWay}"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="1" Header="Source"
                                                          RtfText="{x:Bind StoryWorldVm.Source, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="2" Header="Rules"
                                                          RtfText="{x:Bind StoryWorldVm.Rules, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="3" Header="Limitations"
                                                          RtfText="{x:Bind StoryWorldVm.Limitations, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="4" Header="Cost"
                                                          RtfText="{x:Bind StoryWorldVm.Cost, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="5" Header="Practitioners"
                                                          RtfText="{x:Bind StoryWorldVm.Practitioners, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <usercontrols:RichEditBoxExtended Grid.Row="6" Header="Social Impact"
                                                          RtfText="{x:Bind StoryWorldVm.SocialImpact, Mode=TwoWay}"
                                                          AcceptsReturn="True" IsSpellCheckEnabled="True"
                                                          TextWrapping="Wrap" VerticalAlignment="Stretch"
                                                          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </TabViewItem>

            </TabView.TabItems>
        </TabView>
    </Grid>

</Page>
