<Page NavigationCacheMode="Required"
      x:Class="StoryCAD.Views.StoryWorldPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:usercontrols="using:StoryCADLib.Controls"
      xmlns:storyworld="using:StoryCADLib.Models.StoryWorld"
      mc:Ignorable="d"
      ScrollViewer.VerticalScrollBarVisibility="Disabled"
      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

    <!--
    LAYOUT PATTERN FOR SINGLE-ENTRY TABS WITH MULTIPLE RICHEDITBOXEXTENDED FIELDS:

    Use Grid with star-sized rows + MinHeight, wrapped in outer ScrollViewer.
    NEVER use StackPanel - it removes height constraints and prevents internal scrollbars.

    Required structure:
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>               (Name TextBox)
                    <RowDefinition Height="*" MinHeight="80"/>   (RichEditBox fields)
                    ...
                    <RowDefinition Height="Auto"/>               (Navigation bar)
                </Grid.RowDefinitions>

                <RichEditBoxExtended Grid.Row="N"
                    VerticalAlignment="Stretch"
                    ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </Grid>
        </ScrollViewer>

    This ensures:
    - Uniform height across all fields (star sizing)
    - Fields grow together when window resizes (star sizing)
    - Usable minimum size at small windows (MinHeight)
    - Internal scrollbars when field content overflows (height constraint)
    - Outer scrollbar when total MinHeights exceed viewport (outer ScrollViewer)
    -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with title -->
        <TextBlock Grid.Row="0" Margin="12,8,12,4"
                   Text="{x:Bind StoryWorldVm.Name, Mode=OneWay}"
                   FontSize="20" FontWeight="SemiBold"
                   HorizontalAlignment="Center" />

        <!-- Tab View with 9 tabs -->
        <TabView x:Name="WorldTabView" Grid.Row="1" TabWidthMode="Equal" CanDragTabs="False" CanReorderTabs="False" IsAddTabButtonVisible="False"
                 HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                 HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                 SelectedIndex="{x:Bind StoryWorldVm.SelectedTabIndex, Mode=TwoWay}"
                 SelectionChanged="WorldTabView_SelectionChanged">
            <TabView.TabItems>

                <!-- Tab 1: Structure (World Type Classification) -->
                <TabViewItem Header="Structure" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Question prompt -->
                        <TextBlock Grid.Row="0" Text="What kind of world is your story set in?"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <!-- World Type dropdown -->
                        <ComboBox Grid.Row="1" Header="World Type" MinWidth="350"
                                  ItemsSource="{x:Bind StoryWorldVm.WorldTypeList}"
                                  SelectedItem="{x:Bind StoryWorldVm.WorldType, Mode=TwoWay}"
                                  PlaceholderText="Select the type of world..."/>

                        <!-- Description panel -->
                        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="4" Margin="0,16,0,0" Padding="16">
                            <StackPanel>
                                <TextBlock Text="{x:Bind StoryWorldVm.WorldTypeDescription, Mode=OneWay}"
                                           TextWrapping="Wrap" FontSize="14" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="Works in this category:" FontWeight="SemiBold" FontSize="13"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{x:Bind StoryWorldVm.WorldTypeExamples, Mode=OneWay}"
                                               TextWrapping="Wrap" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Collaborator info and customize button (only visible for Collaborator subscribers) -->
                        <Border Grid.Row="3" Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                BorderBrush="{ThemeResource SystemFillColorNeutralBrush}"
                                BorderThickness="1" CornerRadius="4" Margin="0,16,0,0" Padding="12"
                                Visibility="{x:Bind StoryWorldVm.CollaboratorVisibility, Mode=OneWay}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE946;" FontSize="16" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1" Text="Collaborator uses this to tailor worldbuilding guidance."
                                           VerticalAlignment="Center" TextWrapping="Wrap" FontSize="12"/>
                                <Button Grid.Column="2" Content="Customize AI Parameters"
                                        Command="{x:Bind StoryWorldVm.ShowAiParametersCommand}"
                                        Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabViewItem>

                <!-- Tab 2: Physical Worlds (Single entry view with navigation) -->
                <TabViewItem Header="Physical Worlds" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="4" Padding="0,0,12,0">
                                <TextBox Text="{x:Bind StoryWorldVm.CurrentPhysicalWorldName, Mode=TwoWay}"
                                         PlaceholderText="World name" Header="Name"
                                         IsEnabled="{x:Bind StoryWorldVm.HasPhysicalWorlds, Mode=OneWay}"/>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasPhysicalWorlds, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Geography" FontWeight="{x:Bind StoryWorldVm.PhysicalWorldGeographyFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentPhysicalWorldGeography, Mode=TwoWay}"
                                        PlaceholderText="What are the major landforms, bodies of water, and terrain features?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasPhysicalWorlds, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Climate" FontWeight="{x:Bind StoryWorldVm.PhysicalWorldClimateFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentPhysicalWorldClimate, Mode=TwoWay}"
                                        PlaceholderText="What are the weather patterns, seasons, and extreme conditions?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasPhysicalWorlds, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Natural Resources" FontWeight="{x:Bind StoryWorldVm.PhysicalWorldNaturalResourcesFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentPhysicalWorldNaturalResources, Mode=TwoWay}"
                                        PlaceholderText="What minerals, water sources, and energy are available?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasPhysicalWorlds, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Flora" FontWeight="{x:Bind StoryWorldVm.PhysicalWorldFloraFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentPhysicalWorldFlora, Mode=TwoWay}"
                                        PlaceholderText="What plants, trees, and vegetation exist here?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasPhysicalWorlds, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Fauna" FontWeight="{x:Bind StoryWorldVm.PhysicalWorldFaunaFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentPhysicalWorldFauna, Mode=TwoWay}"
                                        PlaceholderText="What animals, creatures, and wildlife inhabit this world?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasPhysicalWorlds, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Astronomy" FontWeight="{x:Bind StoryWorldVm.PhysicalWorldAstronomyFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentPhysicalWorldAstronomy, Mode=TwoWay}"
                                        PlaceholderText="What moons, stars, and celestial phenomena are visible?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,1,0,0" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Navigation controls (left) -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <Button Command="{x:Bind StoryWorldVm.PreviousPhysicalWorldCommand}"
                                            IsEnabled="{x:Bind StoryWorldVm.HasPreviousPhysicalWorld, Mode=OneWay}"
                                            Padding="8,8" ToolTipService.ToolTip="Previous World">
                                        <SymbolIcon Symbol="Back"/>
                                    </Button>
                                    <TextBlock Text="{x:Bind StoryWorldVm.PhysicalWorldPositionDisplay, Mode=OneWay}"
                                               VerticalAlignment="Center" MinWidth="50" TextAlignment="Center"/>
                                    <Button Command="{x:Bind StoryWorldVm.NextPhysicalWorldCommand}"
                                            IsEnabled="{x:Bind StoryWorldVm.HasNextPhysicalWorld, Mode=OneWay}"
                                            Padding="8,8" ToolTipService.ToolTip="Next World">
                                        <SymbolIcon Symbol="Forward"/>
                                    </Button>
                                </StackPanel>

                                <!-- Add/Remove controls (right) -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                    <Button Command="{x:Bind StoryWorldVm.AddPhysicalWorldCommand}"
                                            Padding="12,8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Add"/>
                                            <TextBlock Text="Add World"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{x:Bind StoryWorldVm.RemoveCurrentPhysicalWorldCommand}"
                                            IsEnabled="{x:Bind StoryWorldVm.HasPhysicalWorlds, Mode=OneWay}"
                                            Padding="12,8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Delete"/>
                                            <TextBlock Text="Remove World"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabViewItem>

                <!-- Tab 3: People/Species (Single entry view with navigation) -->
                <TabViewItem Header="People/Species" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="4" Padding="0,0,12,0">
                                <TextBox Text="{x:Bind StoryWorldVm.CurrentSpeciesName, Mode=TwoWay}"
                                         PlaceholderText="Species name" Header="Name"
                                         IsEnabled="{x:Bind StoryWorldVm.HasSpecies, Mode=OneWay}"/>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasSpecies, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Physical Traits" FontWeight="{x:Bind StoryWorldVm.SpeciesPhysicalTraitsFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentSpeciesPhysicalTraits, Mode=TwoWay}"
                                        PlaceholderText="What do they look like? What physical abilities or limitations do they have?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasSpecies, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Lifespan" FontWeight="{x:Bind StoryWorldVm.SpeciesLifespanFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentSpeciesLifespan, Mode=TwoWay}"
                                        PlaceholderText="How long do they live? What are their life stages?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasSpecies, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Origins" FontWeight="{x:Bind StoryWorldVm.SpeciesOriginsFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentSpeciesOrigins, Mode=TwoWay}"
                                        PlaceholderText="Where did they come from? Evolution, creation, or migration?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasSpecies, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Social Structure" FontWeight="{x:Bind StoryWorldVm.SpeciesSocialStructureFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentSpeciesSocialStructure, Mode=TwoWay}"
                                        PlaceholderText="How do they organize? Family units, tribes, hierarchies?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasSpecies, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Diversity" FontWeight="{x:Bind StoryWorldVm.SpeciesDiversityFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentSpeciesDiversity, Mode=TwoWay}"
                                        PlaceholderText="What subspecies or regional variations exist?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,1,0,0" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <Button Command="{x:Bind StoryWorldVm.PreviousSpeciesCommand}"
                                            IsEnabled="{x:Bind StoryWorldVm.HasPreviousSpecies, Mode=OneWay}"
                                            Padding="8,8" ToolTipService.ToolTip="Previous Species">
                                        <SymbolIcon Symbol="Back"/>
                                    </Button>
                                    <TextBlock Text="{x:Bind StoryWorldVm.SpeciesPositionDisplay, Mode=OneWay}"
                                               VerticalAlignment="Center" MinWidth="50" TextAlignment="Center"/>
                                    <Button Command="{x:Bind StoryWorldVm.NextSpeciesCommand}"
                                            IsEnabled="{x:Bind StoryWorldVm.HasNextSpecies, Mode=OneWay}"
                                            Padding="8,8" ToolTipService.ToolTip="Next Species">
                                        <SymbolIcon Symbol="Forward"/>
                                    </Button>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                    <Button Command="{x:Bind StoryWorldVm.AddSpeciesCommand}" Padding="12,8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Add"/>
                                            <TextBlock Text="Add Species"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{x:Bind StoryWorldVm.RemoveCurrentSpeciesCommand}"
                                            IsEnabled="{x:Bind StoryWorldVm.HasSpecies, Mode=OneWay}" Padding="12,8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Delete"/>
                                            <TextBlock Text="Remove Species"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabViewItem>

                <!-- Tab 4: Cultures (Single entry view with navigation) - Using Expanders -->
                <TabViewItem Header="Cultures" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="4" Padding="0,0,12,0">
                                <TextBox Text="{x:Bind StoryWorldVm.CurrentCultureName, Mode=TwoWay}"
                                         PlaceholderText="Culture name" Header="Name"
                                         IsEnabled="{x:Bind StoryWorldVm.HasCultures, Mode=OneWay}"/>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasCultures, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Values" FontWeight="{x:Bind StoryWorldVm.CultureValuesFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentCultureValues, Mode=TwoWay}"
                                        PlaceholderText="What does this culture believe in? What matters most to them?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasCultures, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Customs" FontWeight="{x:Bind StoryWorldVm.CultureCustomsFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentCultureCustoms, Mode=TwoWay}"
                                        PlaceholderText="What traditions, ceremonies, and social rituals do they practice?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasCultures, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Taboos" FontWeight="{x:Bind StoryWorldVm.CultureTaboosFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentCultureTaboos, Mode=TwoWay}"
                                        PlaceholderText="What behaviors are forbidden or socially unacceptable?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasCultures, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Art" FontWeight="{x:Bind StoryWorldVm.CultureArtFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentCultureArt, Mode=TwoWay}"
                                        PlaceholderText="What music, visual arts, literature, and performance exist?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasCultures, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Daily Life" FontWeight="{x:Bind StoryWorldVm.CultureDailyLifeFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentCultureDailyLife, Mode=TwoWay}"
                                        PlaceholderText="What are their routines, meals, family life, and work patterns?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasCultures, Mode=OneWay}">
                                    <Expander.Header>
                                        <TextBlock Text="Entertainment" FontWeight="{x:Bind StoryWorldVm.CultureEntertainmentFontWeight, Mode=OneWay}"/>
                                    </Expander.Header>
                                    <usercontrols:RichEditBoxExtended
                                        RtfText="{x:Bind StoryWorldVm.CurrentCultureEntertainment, Mode=TwoWay}"
                                        PlaceholderText="What games, sports, and leisure activities do they enjoy?"
                                        AcceptsReturn="True" IsSpellCheckEnabled="True" TextWrapping="Wrap"
                                        MinHeight="150"
                                        ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0" Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <Button Command="{x:Bind StoryWorldVm.PreviousCultureCommand}"
                                                IsEnabled="{x:Bind StoryWorldVm.HasPreviousCulture, Mode=OneWay}"
                                                Padding="8,8" ToolTipService.ToolTip="Previous Culture">
                                            <SymbolIcon Symbol="Back"/>
                                        </Button>
                                        <TextBlock Text="{x:Bind StoryWorldVm.CulturePositionDisplay, Mode=OneWay}"
                                                   VerticalAlignment="Center" MinWidth="50" TextAlignment="Center"/>
                                        <Button Command="{x:Bind StoryWorldVm.NextCultureCommand}"
                                                IsEnabled="{x:Bind StoryWorldVm.HasNextCulture, Mode=OneWay}"
                                                Padding="8,8" ToolTipService.ToolTip="Next Culture">
                                            <SymbolIcon Symbol="Forward"/>
                                        </Button>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                        <Button Command="{x:Bind StoryWorldVm.AddCultureCommand}" Padding="12,8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <SymbolIcon Symbol="Add"/>
                                                <TextBlock Text="Add Culture"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{x:Bind StoryWorldVm.RemoveCurrentCultureCommand}"
                                                IsEnabled="{x:Bind StoryWorldVm.HasCultures, Mode=OneWay}" Padding="12,8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <SymbolIcon Symbol="Delete"/>
                                                <TextBlock Text="Remove Culture"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                </TabViewItem>

                <!-- Tab 5: Governments (Single entry view with navigation) -->
                <TabViewItem Header="Governments" IsClosable="False"
                             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="4" Padding="0,0,12,0">
                                <TextBox Text="{x:Bind StoryWorldVm.CurrentGovernmentName, Mode=TwoWay}"
                                         PlaceholderText="Government name" Header="Name"
                                         IsEnabled="{x:Bind StoryWorldVm.HasGovernments, Mode=OneWay}"/>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          IsEnabled="{x:Bind StoryWorldVm.HasGovernments, Mode=OneWay}">
                                    <Expander.Header>
