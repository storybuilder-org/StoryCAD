<Page NavigationCacheMode="Required"
      x:Class="StoryCAD.Views.WebPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:viewModels="using:StoryCADLib.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBox Header="Name" Text="{x:Bind WebVM.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 viewModels:TextBoxFocus.IsFocused="{x:Bind WebVM.IsTextBoxFocused, Mode=TwoWay}"
                 Grid.Row="0"
                 AutomationProperties.AutomationId="WebNameTextBox" />
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Icon-only buttons: Content is a SymbolIcon with no text, so Name states the
                 function per convention rather than the glyph. -->
            <Button Margin="2,5" Command="{x:Bind WebVM.RefreshCommand, Mode=OneWay}" Grid.Column="0"
                    AutomationProperties.AutomationId="WebRefreshButton"
                    AutomationProperties.Name="Refresh">
                <Button.Content>
                    <SymbolIcon Symbol="Refresh" />
                </Button.Content>
            </Button>
            <Button Margin="2,5" Command="{x:Bind WebVM.GoBackCommand, Mode=OneWay}" Grid.Column="1"
                    AutomationProperties.AutomationId="WebBackButton"
                    AutomationProperties.Name="Back">
                <Button.Content>
                    <SymbolIcon Symbol="Back" />
                </Button.Content>
            </Button>
            <Button Margin="2,5" Command="{x:Bind WebVM.GoForwardCommand, Mode=OneWay}" Grid.Column="2"
                    AutomationProperties.AutomationId="WebForwardButton"
                    AutomationProperties.Name="Forward">
                <Button.Content>
                    <SymbolIcon Symbol="Forward" />
                </Button.Content>
            </Button>
            <!-- PlaceholderText only, no Header: explicit Name required per convention. -->
            <AutoSuggestBox HorizontalAlignment="Stretch" Text="{x:Bind WebVM.Query, Mode=TwoWay}" Margin="2,8"
                            Grid.Column="3" PlaceholderText="Enter a URL or Query here!"
                            QueryIcon="Find" QuerySubmitted="QuerySubmitted"
                            AutomationProperties.AutomationId="WebSearchBox"
                            AutomationProperties.Name="Navigate or search" />
        </Grid>
        <WebView2 Name="WebView" Grid.Row="2" Source="{x:Bind WebVM.Url, Mode=TwoWay}"
                  NavigationCompleted="Web_OnNavigationCompleted" />
    </Grid>
</Page>
